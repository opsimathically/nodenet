{
  "schemaVersion": 2,
  "release": "0.2.0-rc.1",
  "platform": {
    "os": "linux",
    "architectures": ["x86_64", "aarch64"],
    "libc": "glibc >=2.28",
    "kernel": ">=4.18",
    "node": ">=26.0.0",
    "nodeApi": 10
  },
  "limits": {
    "scannersPerEnvironment": 4,
    "sessionsPerEnvironment": 4,
    "pendingOperationsPerEnvironment": 64,
    "controlItemsMaximum": 65536,
    "controlBytesMaximum": 4194304,
    "resultBatchRowsMaximum": 4096,
    "resultMetadataBytesMaximum": 4194304
  },
  "resultBatchSchema": {
    "emittedVersion": 2,
    "acceptedVersions": [1, 2],
    "byteOrder": "little-endian",
    "addressByteOrder": "network"
  },
  "udpProbeCatalogue": {
    "version": "1.4.1",
    "protocolVariants": 37,
    "safeVariants": 9,
    "blockedCapabilities": 13,
    "defaultProfile": "safe",
    "defaultStrategy": "exhaustive"
  },
  "udpCoverageRegistry": {
    "version": "1.1.0",
    "candidates": 41,
    "implemented": 5,
    "noGo": 32,
    "excluded": 4
  },
  "artifacts": [
    "@opsimathically/nodenetscanner",
    "@opsimathically/nodenetscanner-linux-x64-gnu",
    "@opsimathically/nodenetscanner-linux-arm64-gnu"
  ],
  "unsupported": [
    "non-Linux",
    "musl",
    "32-bit architectures",
    "connect scanning",
    "complete service/version or operating-system fingerprinting",
    "firewall or namespace mutation",
    "AF_XDP",
    "published AArch64 artifacts until native AArch64 execution passes"
  ]
}
