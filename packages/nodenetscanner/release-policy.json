{
  "schemaVersion": 1,
  "release": "0.1.0-rc.1",
  "platform": {
    "os": "linux",
    "architectures": ["x86_64", "aarch64"],
    "libc": "glibc >=2.28",
    "kernel": ">=4.18",
    "node": ">=26.0.0",
    "nodeApi": 10
  },
  "limits": {
    "scannersPerEnvironment": 4,
    "sessionsPerEnvironment": 4,
    "pendingOperationsPerEnvironment": 64,
    "controlItemsMaximum": 65536,
    "controlBytesMaximum": 4194304,
    "resultBatchRowsMaximum": 4096,
    "resultMetadataBytesMaximum": 4194304
  },
  "resultBatchSchema": {
    "version": 1,
    "byteOrder": "little-endian",
    "addressByteOrder": "network"
  },
  "artifacts": [
    "@opsimathically/nodenetscanner",
    "@opsimathically/nodenetscanner-linux-x64-gnu",
    "@opsimathically/nodenetscanner-linux-arm64-gnu"
  ],
  "unsupported": [
    "non-Linux",
    "musl",
    "32-bit architectures",
    "connect scanning",
    "service or operating-system fingerprinting",
    "firewall or namespace mutation",
    "AF_XDP"
  ]
}
